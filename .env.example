# Ollama 자체 호스팅 LLM (필수)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"

# Supabase JS 클라이언트 (필수)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"  # 회원탈퇴 API용 (Project Settings → API → service_role)

# 클라이언트 컴포넌트용 (NEXT_PUBLIC_ 필수)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# Supabase PostgreSQL (Session Mode Pooler - for app queries)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase PostgreSQL (Direct Connection - for migrations)
DIRECT_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
